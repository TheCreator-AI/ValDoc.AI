{
  "name": "valdoc-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "config:check": "tsx scripts/check-config.ts",
    "predev": "npm run config:check",
    "prebuild": "npm run config:check",
    "prestart": "npm run config:check",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:sast": "semgrep scan --config p/javascript --config p/typescript --error --severity ERROR src",
    "secrets:scan": "gitleaks detect --source . --config .gitleaks.toml --no-banner --redact",
    "security:check": "npm run security:audit && npm run security:sast && npm run secrets:scan",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "provision": "tsx scripts/provision.ts",
    "backup_db": "tsx scripts/backup_db.ts",
    "restore_db": "tsx scripts/restore_db.ts",
    "verify_restore": "tsx scripts/verify_restore.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@types/yazl": "^3.3.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^3.0.3",
    "docx": "^9.5.2",
    "formidable": "^3.5.4",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "prisma": "^6.16.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^13.0.0",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
