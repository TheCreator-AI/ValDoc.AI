{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valdoc.ai/schemas/tm.v1.json",
  "title": "Traceability Matrix v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "revision_history", "mappings"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_type", "doc_version", "system_name", "equipment_id", "generated_at", "generated_by"],
      "properties": {
        "doc_type": { "const": "TM" },
        "doc_version": { "type": "string", "pattern": "^v[0-9]+(\\.[0-9]+)?$" },
        "system_name": { "type": "string", "minLength": 1 },
        "equipment_id": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "generated_by": { "type": "string", "minLength": 1 }
      }
    },
    "revision_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "changed_at", "changed_by", "change_summary"],
        "properties": {
          "version": { "type": "string", "minLength": 1 },
          "changed_at": { "type": "string", "format": "date-time" },
          "changed_by": { "type": "string", "minLength": 1 },
          "change_summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["req_id", "risk_ids", "test_ids", "output_reference"],
        "properties": {
          "req_id": { "type": "string", "minLength": 1 },
          "risk_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "test_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "output_reference": {
            "type": "object",
            "additionalProperties": false,
            "required": ["template_doc_type", "output_document_ref", "output_section_ref"],
            "properties": {
              "template_doc_type": { "enum": ["URS", "RA", "IOQ", "OQ", "TM"] },
              "output_document_ref": { "type": "string", "minLength": 1 },
              "output_section_ref": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
