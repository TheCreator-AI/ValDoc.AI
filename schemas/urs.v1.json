{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valdoc.ai/schemas/urs.v1.json",
  "title": "URS v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "revision_history", "requirements"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_type", "doc_version", "system_name", "equipment_id", "generated_at", "generated_by"],
      "properties": {
        "doc_type": { "const": "URS" },
        "doc_version": { "type": "string", "pattern": "^v[0-9]+(\\.[0-9]+)?$" },
        "system_name": { "type": "string", "minLength": 1 },
        "equipment_id": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "generated_by": { "type": "string", "minLength": 1 }
      }
    },
    "revision_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "changed_at", "changed_by", "change_summary"],
        "properties": {
          "version": { "type": "string", "minLength": 1 },
          "changed_at": { "type": "string", "format": "date-time" },
          "changed_by": { "type": "string", "minLength": 1 },
          "change_summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "req_id",
          "category",
          "statement",
          "rationale",
          "source_refs",
          "acceptance_criteria",
          "test_method",
          "criticality",
          "linked_risk_ids"
        ],
        "properties": {
          "req_id": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "pattern": "\\bshall\\b" },
          "rationale": { "type": "string", "minLength": 1 },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "acceptance_criteria": { "type": "string", "minLength": 1 },
          "test_method": { "enum": ["IQ", "OQ", "Doc Review"] },
          "criticality": { "enum": ["HIGH", "MEDIUM", "LOW"] },
          "linked_risk_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
