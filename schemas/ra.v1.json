{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valdoc.ai/schemas/ra.v1.json",
  "title": "Risk Assessment v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "revision_history", "risks"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_type", "doc_version", "system_name", "equipment_id", "generated_at", "generated_by"],
      "properties": {
        "doc_type": { "const": "RA" },
        "doc_version": { "type": "string", "pattern": "^v[0-9]+(\\.[0-9]+)?$" },
        "system_name": { "type": "string", "minLength": 1 },
        "equipment_id": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "generated_by": { "type": "string", "minLength": 1 }
      }
    },
    "revision_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "changed_at", "changed_by", "change_summary"],
        "properties": {
          "version": { "type": "string", "minLength": 1 },
          "changed_at": { "type": "string", "format": "date-time" },
          "changed_by": { "type": "string", "minLength": 1 },
          "change_summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk_id",
          "hazard",
          "cause",
          "impact",
          "severity",
          "occurrence",
          "detection",
          "initial_risk",
          "controls",
          "residual_risk",
          "linked_req_ids",
          "verification_test_ids"
        ],
        "properties": {
          "risk_id": { "type": "string", "minLength": 1 },
          "hazard": { "type": "string", "minLength": 1 },
          "cause": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "severity": { "type": "integer", "minimum": 1, "maximum": 5 },
          "occurrence": { "type": "integer", "minimum": 1, "maximum": 5 },
          "detection": { "type": "integer", "minimum": 1, "maximum": 5 },
          "initial_risk": { "type": "integer", "minimum": 1 },
          "controls": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "residual_risk": { "type": "integer", "minimum": 1 },
          "linked_req_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "verification_test_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
